generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  OWNER
  ADMIN
  STAFF
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum SystemModule {
  CORE
  DASHBOARD
  CLIENTS
  FINANCE
  REPORTS
  SETTINGS
  CARRETA_KIDS
  RENTAL
  PLUSH
  BILLIARD
  BRASIL_BETS
  MACHINE
  CONDOMINIUM_MARKET
  MARKETING
  PERSONAL_FINANCE
  BX
  SLOT_H
}

enum PersonType {
  INDIVIDUAL
  COMPANY
}

enum ClientStatus {
  ACTIVE
  INACTIVE
  DELINQUENT
  EXCEPTION
}

enum PaymentMethod {
  CASH
  PIX
  CREDIT_CARD
  DEBIT_CARD
  BANK_TRANSFER
  BOLETO
  CHECK
  OTHER
}

enum FinancialDirection {
  INCOME
  EXPENSE
}

enum FinancialKind {
  RECEIVABLE
  PAYABLE
  EXPENSE
  REVENUE
  ADJUSTMENT
  DEBT
  NEGATIVE
  COMMISSION
}

enum FinancialStatus {
  DRAFT
  PENDING
  PARTIAL
  PAID
  OVERDUE
  CANCELLED
}

enum FileCategory {
  CLIENT_DOCUMENT
  PROOF
  PHOTO
  CONTRACT
  GUARANTEE
  RECEIPT
  OTHER
}

enum NotificationChannel {
  EMAIL
  WHATSAPP
  SYSTEM
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
  CANCELLED
}

enum ReminderStatus {
  OPEN
  DONE
  CANCELLED
}

enum RentalStatus {
  DRAFT
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum ContractStatus {
  DRAFT
  PENDING_SIGNATURE
  ACTIVE
  CLOSED
  DEFAULTED
  CANCELLED
}

enum MaintenanceStatus {
  SCHEDULED
  DONE
  CANCELLED
}

enum BxReceiptStatus {
  RECEIVED
  NOT_RECEIVED
}

enum MachineCompensationStatus {
  WORTH_IT
  NOT_WORTH_IT
}

enum PersonalEntryType {
  INCOME
  EXPENSE
  PAYABLE
  PAID
}

enum SlotDebtMode {
  DEBT
  NEGATIVE
  NONE
}

enum FieldVisitType {
  BILLIARD
  PLUSH
  BX
  SLOT_H
  CARRETA_KIDS
  RENTAL
  GENERAL
}

enum EntityType {
  ORGANIZATION
  USER
  CLIENT
  FINANCIAL_ENTRY
  PAYMENT
  NOTE
  REMINDER
  CARRETA_KIDS
  RENTAL
  PLUSH_COLLECTION
  BILLIARD_COLLECTION
  BRAZIL_BETS
  MACHINE_CONTRACT
  MARKETING_CONTRACT
  BX_TRANSACTION
  SLOT_COLLECTION
  FILE
  OTHER
}

model FieldVisit {
  id             String         @id @default(cuid())
  organizationId String
  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  clientId       String?
  client         Client?        @relation(fields: [clientId], references: [id], onDelete: SetNull)
  targetId       String?
  clientName     String?
  clientPhone    String?
  createdById    String?
  createdBy      User?          @relation("VisitCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  visitType      FieldVisitType @default(GENERAL)
  occurredAt     DateTime
  checkedItems   String[]
  incomeAmount   Decimal        @default(0) @db.Decimal(14, 2)
  expenseAmount  Decimal        @default(0) @db.Decimal(14, 2)
  notes          String?
  createdAt      DateTime       @default(now())

  @@index([organizationId, occurredAt])
  @@index([clientId])
  @@index([organizationId, targetId])
}

model Organization {
  id                       String                   @id @default(cuid())
  name                     String
  slug                     String                   @unique
  legalName                String?
  document                 String?
  phone                    String?
  email                    String?
  createdAt                DateTime                 @default(now())
  updatedAt                DateTime                 @updatedAt
  users                    User[]
  modulePermissions        ModulePermission[]
  settings                 SystemSetting[]
  clients                  Client[]
  financialAccounts        FinancialAccount[]
  financialCategories      FinancialCategory[]
  financialEntries         FinancialEntry[]
  payments                 Payment[]
  fileAssets               FileAsset[]
  notes                    Note[]
  reminders                Reminder[]
  notifications            Notification[]
  auditLogs                AuditLog[]
  moduleClients            ModuleClient[]
  carretaKidsRecords       CarretaKidsRecord[]
  rentalOrders             RentalOrder[]
  plushMachines            PlushMachine[]
  plushCollections         PlushCollection[]
  billiardPoints           BilliardPoint[]
  billiardCollections      BilliardCollection[]
  billiardMaintenances     BilliardMaintenance[]
  routePlans               RoutePlan[]
  brazilBetsEntries        BrazilBetsEntry[]
  machineContracts         MachineContract[]
  machineGuarantees        MachineGuarantee[]
  condominiumMarketEntries CondominiumMarketEntry[]
  marketingContracts       MarketingContract[]
  personalFinanceRecords   PersonalFinanceRecord[]
  bxTransactions           BxTransaction[]
  slotMachines             SlotMachine[]
  slotCollections          SlotCollection[]
  fieldVisits              FieldVisit[]
}

model User {
  id                String             @id @default(cuid())
  organizationId    String
  organization      Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  role              UserRole
  status            UserStatus         @default(ACTIVE)
  name              String
  email             String             @unique
  phone             String?
  passwordHash      String
  lastLoginAt       DateTime?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  modulePermissions ModulePermission[]
  uploadedFiles     FileAsset[]
  createdClients    Client[]           @relation("ClientCreatedBy")
  paymentsCreated   Payment[]          @relation("PaymentCreatedBy")
  auditLogs         AuditLog[]
  notesCreated      Note[]             @relation("NoteCreatedBy")
  remindersCreated  Reminder[]         @relation("ReminderCreatedBy")
  remindersAssigned Reminder[]         @relation("ReminderAssignedTo")
  fieldVisits       FieldVisit[]       @relation("VisitCreatedBy")
}

model ModulePermission {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  module         SystemModule
  canView        Boolean      @default(false)
  canCreate      Boolean      @default(false)
  canUpdate      Boolean      @default(false)
  canDelete      Boolean      @default(false)
  canApprove     Boolean      @default(false)
  canExport      Boolean      @default(false)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([userId, module])
  @@index([organizationId, module])
}

model SystemSetting {
  id             String        @id @default(cuid())
  organizationId String
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  module         SystemModule?
  key            String
  value          Json
  updatedById    String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@unique([organizationId, key])
  @@index([organizationId, module])
}

model Client {
  id             String           @id @default(cuid())
  organizationId String
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  code           String
  name           String
  personType     PersonType       @default(INDIVIDUAL)
  phone          String?
  email          String?
  cpf            String?
  cnpj           String?
  document       String?
  street         String?
  neighborhood   String?
  city           String?
  state          String?
  postalCode     String?
  notes          String?
  status         ClientStatus     @default(ACTIVE)
  registeredAt   DateTime         @default(now())
  createdById    String?
  createdBy      User?            @relation("ClientCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedAt      DateTime         @updatedAt
  financialItems FinancialEntry[]
  rentalOrders   RentalOrder[]
  plushMachines  PlushMachine[]
  billiardPoints BilliardPoint[]
  bxTransactions BxTransaction[]
  slotMachines   SlotMachine[]
  moduleClients  ModuleClient[]
  fieldVisits    FieldVisit[]

  @@unique([organizationId, code])
  @@index([organizationId, name])
  @@index([organizationId, status])
}

model ModuleClient {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  clientId       String
  client         Client       @relation(fields: [clientId], references: [id], onDelete: Cascade)
  module         SystemModule
  moduleCode     String?
  notes          String?
  isActive       Boolean      @default(true)
  createdById    String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([organizationId, clientId, module])
  @@index([organizationId, module])
  @@index([clientId])
}

model FinancialAccount {
  id             String           @id @default(cuid())
  organizationId String
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  description    String?
  isActive       Boolean          @default(true)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  entries        FinancialEntry[]

  @@unique([organizationId, name])
}

model FinancialCategory {
  id             String             @id @default(cuid())
  organizationId String
  organization   Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  direction      FinancialDirection
  module         SystemModule?
  isActive       Boolean            @default(true)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  entries        FinancialEntry[]

  @@unique([organizationId, name])
  @@index([organizationId, direction])
}

model FinancialEntry {
  id                String             @id @default(cuid())
  organizationId    String
  organization      Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  clientId          String?
  client            Client?            @relation(fields: [clientId], references: [id], onDelete: SetNull)
  accountId         String?
  account           FinancialAccount?  @relation(fields: [accountId], references: [id], onDelete: SetNull)
  categoryId        String?
  category          FinancialCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  module            SystemModule
  kind              FinancialKind
  direction         FinancialDirection
  status            FinancialStatus    @default(PENDING)
  description       String
  referenceCode     String?
  sourceEntityType  EntityType?
  sourceEntityId    String?
  issueDate         DateTime           @default(now())
  dueDate           DateTime?
  paidAt            DateTime?
  totalAmount       Decimal            @db.Decimal(14, 2)
  paidAmount        Decimal            @default(0) @db.Decimal(14, 2)
  discountAmount    Decimal            @default(0) @db.Decimal(14, 2)
  interestAmount    Decimal            @default(0) @db.Decimal(14, 2)
  remainingAmount   Decimal            @db.Decimal(14, 2)
  installmentsCount Int                @default(1)
  paymentMethod     PaymentMethod?
  notes             String?
  createdById       String?
  approvedById      String?
  approvedAt        DateTime?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  payments          Payment[]

  @@index([organizationId, module])
  @@index([organizationId, status])
  @@index([organizationId, dueDate])
  @@index([clientId])
}

model Payment {
  id               String         @id @default(cuid())
  organizationId   String
  organization     Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  financialEntryId String
  financialEntry   FinancialEntry @relation(fields: [financialEntryId], references: [id], onDelete: Cascade)
  amount           Decimal        @db.Decimal(14, 2)
  paymentDate      DateTime       @default(now())
  method           PaymentMethod
  proofFileId      String?
  proofFile        FileAsset?     @relation("PaymentProof", fields: [proofFileId], references: [id], onDelete: SetNull)
  notes            String?
  createdById      String?
  createdBy        User?          @relation("PaymentCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt        DateTime       @default(now())

  @@index([organizationId, paymentDate])
}

model FileAsset {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  uploadedById   String?
  uploadedBy     User?        @relation(fields: [uploadedById], references: [id], onDelete: SetNull)
  category       FileCategory
  entityType     EntityType?
  entityId       String?
  originalName   String
  fileName       String
  mimeType       String
  size           Int
  storagePath    String
  createdAt      DateTime     @default(now())
  paymentProofs  Payment[]    @relation("PaymentProof")

  @@index([organizationId, entityType, entityId])
}

model Note {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  title          String
  content        String
  pinned         Boolean      @default(false)
  createdById    String?
  createdBy      User?        @relation("NoteCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([organizationId, pinned])
}

model Reminder {
  id             String         @id @default(cuid())
  organizationId String
  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  title          String
  description    String?
  dueAt          DateTime
  status         ReminderStatus @default(OPEN)
  assignedToId   String?
  assignedTo     User?          @relation("ReminderAssignedTo", fields: [assignedToId], references: [id], onDelete: SetNull)
  createdById    String?
  createdBy      User?          @relation("ReminderCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@index([organizationId, dueAt])
  @@index([organizationId, status])
}

model Notification {
  id             String              @id @default(cuid())
  organizationId String
  organization   Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  module         SystemModule?
  channel        NotificationChannel
  status         NotificationStatus  @default(PENDING)
  title          String
  message        String
  recipientName  String?
  recipientPhone String?
  recipientEmail String?
  referenceId    String?
  payload        Json?
  scheduledAt    DateTime?
  sentAt         DateTime?
  createdAt      DateTime            @default(now())

  @@index([organizationId, status])
  @@index([organizationId, channel])
}

model AuditLog {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String?
  user           User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  module         SystemModule
  action         String
  entityType     EntityType
  entityId       String
  oldData        Json?
  newData        Json?
  createdAt      DateTime     @default(now())

  @@index([organizationId, module])
  @@index([organizationId, entityType, entityId])
}

model CarretaKidsRecord {
  id             String         @id @default(cuid())
  organizationId String
  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  clientId       String?
  locationName   String
  serviceDate    DateTime
  sheetName      String
  phone          String?
  minutesCharged Int
  tablePrice     Decimal        @db.Decimal(14, 2)
  totalAmount    Decimal        @db.Decimal(14, 2)
  paymentMethod  PaymentMethod?
  entryAmount    Decimal?       @db.Decimal(14, 2)
  exitAmount     Decimal?       @db.Decimal(14, 2)
  entryTime      String?
  exitTime       String?
  expenseAmount  Decimal?       @db.Decimal(14, 2)
  notes          String?
  createdById    String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@index([organizationId, serviceDate])
}

model RentalOrder {
  id               String          @id @default(cuid())
  organizationId   String
  organization     Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  clientId         String?
  client           Client?         @relation(fields: [clientId], references: [id], onDelete: SetNull)
  clientName       String?
  phone            String?
  document         String?
  localName        String
  eventDate        DateTime
  totalAmount      Decimal         @db.Decimal(14, 2)
  signalPercentage Decimal?        @db.Decimal(5, 2)
  signalAmount     Decimal?        @db.Decimal(14, 2)
  balanceAmount    Decimal?        @db.Decimal(14, 2)
  expenseAmount    Decimal?        @db.Decimal(14, 2)
  paymentMethod    PaymentMethod?
  paymentStatus    FinancialStatus @default(PENDING)
  contractNumber   String?
  notes            String?
  status           RentalStatus    @default(DRAFT)
  createdById      String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@index([organizationId, eventDate])
}

model PlushMachine {
  id             String            @id @default(cuid())
  organizationId String
  organization   Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  clientId       String?
  client         Client?           @relation(fields: [clientId], references: [id], onDelete: SetNull)
  clientName     String?
  cpf            String?
  phone          String?
  code           String
  name           String
  machineNumber  String
  noteNumber     String?
  noteiroFixed   String?           @default("01")
  coinPhotoRule  Boolean           @default(true)
  giftPhotoRule  Boolean           @default(true)
  active         Boolean           @default(true)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  collections    PlushCollection[]

  @@unique([organizationId, code])
  @@unique([organizationId, machineNumber])
}

model PlushCollection {
  id                   String                    @id @default(cuid())
  organizationId       String
  organization         Organization              @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  plushMachineId       String
  plushMachine         PlushMachine              @relation(fields: [plushMachineId], references: [id], onDelete: Cascade)
  clientId             String?
  grossAmount          Decimal                   @db.Decimal(14, 2)
  commissionPercentage Decimal                   @default(25) @db.Decimal(5, 2)
  clientAmount         Decimal                   @db.Decimal(14, 2)
  companyAmount        Decimal                   @db.Decimal(14, 2)
  plushCountOut        Int                       @default(0)
  paymentMethod        PaymentMethod?
  discountAmount       Decimal                   @default(0) @db.Decimal(14, 2)
  discountReason       String?
  ownerExpenseAmount   Decimal                   @default(0) @db.Decimal(14, 2)
  compensationStatus   MachineCompensationStatus
  noteiro              String?
  coinPhotoId          String?
  giftPhotoId          String?
  createdById          String?
  createdAt            DateTime                  @default(now())
  updatedAt            DateTime                  @updatedAt

  @@index([organizationId, createdAt])
}

model BilliardPoint {
  id                 String                @id @default(cuid())
  organizationId     String
  organization       Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  clientId           String?
  client             Client?               @relation(fields: [clientId], references: [id], onDelete: SetNull)
  registrationNumber Int?
  code               String
  name               String
  clientName         String?
  cep                String?
  street             String?
  neighborhood       String?
  city               String?
  state              String?
  phone              String?
  cpf                String?
  cnpj               String?
  tableModel         String?
  chipValue          Decimal?              @db.Decimal(14, 2)
  roofOpenDebt       Decimal?              @db.Decimal(14, 2)
  routeNumber        Int?
  partialRoute       String?
  accumulatedChips   Int                   @default(0)
  clothChangeAlertAt Int                   @default(1500)
  createdById        String?
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt
  collections        BilliardCollection[]
  maintenances       BilliardMaintenance[]

  @@unique([organizationId, code])
  @@unique([organizationId, registrationNumber])
}

model BilliardCollection {
  id                String         @id @default(cuid())
  organizationId    String
  organization      Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  billiardPointId   String
  billiardPoint     BilliardPoint  @relation(fields: [billiardPointId], references: [id], onDelete: Cascade)
  collectionDate    DateTime
  quantityOfChips   Int
  grossAmount       Decimal        @db.Decimal(14, 2)
  percentage        Decimal?       @db.Decimal(5, 2)
  discountAmount    Decimal?       @db.Decimal(14, 2)
  roofAmount        Decimal?       @db.Decimal(14, 2)
  roofPaymentMethod PaymentMethod?
  employeeCost      Decimal?       @db.Decimal(14, 2)
  installationCost  Decimal?       @db.Decimal(14, 2)
  maintenanceCost   Decimal?       @db.Decimal(14, 2)
  otherCost         Decimal?       @db.Decimal(14, 2)
  photoId           String?
  registerNumber    String?
  createdById       String?
  createdAt         DateTime       @default(now())

  @@index([organizationId, collectionDate])
}

model BilliardMaintenance {
  id              String            @id @default(cuid())
  organizationId  String
  organization    Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  billiardPointId String
  billiardPoint   BilliardPoint     @relation(fields: [billiardPointId], references: [id], onDelete: Cascade)
  maintenanceDate DateTime
  materials       String?
  notes           String?
  status          MaintenanceStatus @default(SCHEDULED)
  createdById     String?
  createdAt       DateTime          @default(now())

  @@index([organizationId, maintenanceDate])
}

model RoutePlan {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  code           String
  name           String
  routeNumber    Int
  description    String?
  createdById    String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([organizationId, code])
}

model BrazilBetsEntry {
  id             String             @id @default(cuid())
  organizationId String
  organization   Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  movementDate   DateTime
  description    String
  direction      FinancialDirection
  status         FinancialStatus    @default(PENDING)
  amount         Decimal            @db.Decimal(14, 2)
  paymentMethod  PaymentMethod?
  notes          String?
  createdById    String?
  createdAt      DateTime           @default(now())

  @@index([organizationId, movementDate])
}

model MachineContract {
  id                   String             @id @default(cuid())
  organizationId       String
  organization         Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  clientCode           String
  clientName           String
  amount               Decimal            @db.Decimal(14, 2)
  contractDate         DateTime
  year                 Int
  percentage           Decimal?           @db.Decimal(5, 2)
  monthlyInterest      Decimal?           @db.Decimal(5, 2)
  installmentFixed     Boolean            @default(false)
  guaranteeEnabled     Boolean            @default(false)
  signatureLink        String?
  signatureFileId      String?
  streetLoanAmount     Decimal?           @db.Decimal(14, 2)
  monthlyInterestTotal Decimal?           @db.Decimal(14, 2)
  generalPercentageAvg Decimal?           @db.Decimal(5, 2)
  expenseAmount        Decimal?           @db.Decimal(14, 2)
  paymentMethod        PaymentMethod?
  status               ContractStatus     @default(DRAFT)
  notes                String?
  createdById          String?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  guarantees           MachineGuarantee[]

  @@index([organizationId, contractDate])
}

model MachineGuarantee {
  id                String           @id @default(cuid())
  organizationId    String
  organization      Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  machineContractId String?
  machineContract   MachineContract? @relation(fields: [machineContractId], references: [id], onDelete: SetNull)
  code              String
  description       String?
  status            ContractStatus   @default(DRAFT)
  fileId            String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  @@unique([organizationId, code])
}

model CondominiumMarketEntry {
  id             String             @id @default(cuid())
  organizationId String
  organization   Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  movementDate   DateTime
  description    String
  direction      FinancialDirection
  amount         Decimal            @db.Decimal(14, 2)
  expenseAmount  Decimal?           @db.Decimal(14, 2)
  paymentMethod  PaymentMethod?
  notes          String?
  createdAt      DateTime           @default(now())

  @@index([organizationId, movementDate])
}

model MarketingContract {
  id               String         @id @default(cuid())
  organizationId   String
  organization     Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name             String
  personType       PersonType
  cpf              String?
  cnpj             String?
  serviceType      String
  contractValue    Decimal        @db.Decimal(14, 2)
  contractDate     DateTime
  address          String?
  phone            String?
  email            String?
  signatureLink    String?
  signatureFileId  String?
  expenseAmount    Decimal?       @db.Decimal(14, 2)
  paymentMethod    PaymentMethod?
  status           ContractStatus @default(DRAFT)
  generatedFileId  String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@index([organizationId, contractDate])
}

model PersonalFinanceRecord {
  id             String            @id @default(cuid())
  organizationId String
  organization   Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  title          String
  type           PersonalEntryType
  category       String
  amount         Decimal           @db.Decimal(14, 2)
  dueDate        DateTime?
  paidAt         DateTime?
  paymentMethod  PaymentMethod?
  notes          String?
  createdById    String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@index([organizationId, type])
}

model BxTransaction {
  id                String          @id @default(cuid())
  organizationId    String
  organization      Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  clientId          String?
  client            Client?         @relation(fields: [clientId], references: [id], onDelete: SetNull)
  clientName        String
  phone             String?
  cpf               String?
  cep               String?
  street            String?
  neighborhood      String?
  city              String?
  state             String?
  collectNumber     String?
  occurredAt        DateTime
  agentName         String?
  receiverName      String?
  sentToAgentAmount Decimal?        @db.Decimal(14, 2)
  deliveredAmount   Decimal?        @db.Decimal(14, 2)
  incomeAmount      Decimal?        @db.Decimal(14, 2)
  expenseAmount     Decimal?        @db.Decimal(14, 2)
  totalAmount       Decimal         @db.Decimal(14, 2)
  discountAmount    Decimal?        @db.Decimal(14, 2)
  paymentMethod     PaymentMethod?
  employeeFilled    Boolean         @default(true)
  screenPhotoId     String?
  paperPhotoId      String?
  exceptionClient   Boolean         @default(false)
  receiptStatus     BxReceiptStatus @default(NOT_RECEIVED)
  createdById       String?
  createdAt         DateTime        @default(now())

  @@index([organizationId, occurredAt])
}

model SlotMachine {
  id                   String           @id @default(cuid())
  organizationId       String
  organization         Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  clientId             String?
  client               Client?          @relation(fields: [clientId], references: [id], onDelete: SetNull)
  uniqueMachineNumber  String
  clientSequenceNumber String
  clientName           String?
  phone                String?
  cpf                  String?
  cep                  String?
  street               String?
  neighborhood         String?
  city                 String?
  state                String?
  customerDebt         Decimal?         @db.Decimal(14, 2)
  ppValue              Decimal?         @db.Decimal(14, 2)
  initialAmount        Decimal?         @db.Decimal(14, 2)
  initialAmountMode    SlotDebtMode     @default(NONE)
  optionalGreedAmount  Decimal?         @db.Decimal(14, 2)
  active               Boolean          @default(true)
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
  collections          SlotCollection[]

  @@unique([organizationId, uniqueMachineNumber])
}

model SlotCollection {
  id                     String         @id @default(cuid())
  organizationId         String
  organization           Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  slotMachineId          String
  slotMachine            SlotMachine    @relation(fields: [slotMachineId], references: [id], onDelete: Cascade)
  occurredAt             DateTime
  currentIncome          Decimal        @db.Decimal(14, 2)
  previousIncome         Decimal        @db.Decimal(14, 2)
  incomeDifference       Decimal        @db.Decimal(14, 2)
  currentExpense         Decimal        @db.Decimal(14, 2)
  previousExpense        Decimal        @db.Decimal(14, 2)
  expenseDifference      Decimal        @db.Decimal(14, 2)
  percentageSplit        Decimal        @default(50) @db.Decimal(5, 2)
  conferenceCount        Int            @default(0)
  negativeAmount         Decimal?       @db.Decimal(14, 2)
  feedingNegativeAmount  Decimal?       @db.Decimal(14, 2)
  customerDebtDiscounted Decimal?       @db.Decimal(14, 2)
  generatedDebtAmount    Decimal?       @db.Decimal(14, 2)
  debtMode               SlotDebtMode   @default(NONE)
  paymentMethod          PaymentMethod?
  createdById            String?
  createdAt              DateTime       @default(now())

  @@index([organizationId, occurredAt])
}
